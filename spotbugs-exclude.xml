<FindBugsFilter>
    <!-- Lombok @Builder.Default gera acesso a campo mutavel que o SpotBugs confunde com exposicao interna -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Package name="br.com.fiap.agendamento.domain.model"/>
    </Match>
    <!-- Records de DTO na borda da API: falso positivo de exposicao de representacao interna -->
    <Match>
        <Package name="br.com.fiap.agendamento.application.dto"/>
    </Match>
    <!-- Injecao de dependencia via construtor (Spring): armazenar o bean injetado
         (ex: JwtAuthenticationFilter) e o padrao normal de DI, nao uma falha real. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Package name="br.com.fiap.agendamento.infrastructure.security"/>
    </Match>
</FindBugsFilter>
