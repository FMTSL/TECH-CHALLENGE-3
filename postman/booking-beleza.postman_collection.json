  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Calcula uma data 7 dias a frente (sempre no futuro, nao importa quando voce rodar a colecao)",
          "const dias = ['DOMINGO','SEGUNDA','TERCA','QUARTA','QUINTA','SEXTA','SABADO'];",
          "const d = new Date();",
          "d.setDate(d.getDate() + 7);",
          "const yyyy = d.getFullYear();",
          "const mm = String(d.getMonth()+1).padStart(2,'0');",
          "const dd = String(d.getDate()).padStart(2,'0');",
          "pm.collectionVariables.set('dataFutura', `${yyyy}-${mm}-${dd}`);",
          "pm.collectionVariables.set('diaSemanaFutura', dias[d.getDay()]);",
          "pm.collectionVariables.set('dataHoraFutura', `${yyyy}-${mm}-${dd}T09:00:00`);"
        ]
      }
    }
  ],
