{
  "family": "booking-beleza",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "booking-beleza-app",
      "image": "<SEU_REGISTRY>/booking-beleza:latest",
      "portMappings": [{ "containerPort": 8080, "protocol": "tcp" }],
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "docker" }
      ],
      "secrets": [
        { "name": "SPRING_DATASOURCE_URL", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/booking-beleza/db-url" },
        { "name": "SPRING_DATASOURCE_USERNAME", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/booking-beleza/db-user" },
        { "name": "SPRING_DATASOURCE_PASSWORD", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/booking-beleza/db-password" },
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/booking-beleza/jwt-secret" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/booking-beleza",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "app"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8080/actuator/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3
      }
    }
  ]
}
